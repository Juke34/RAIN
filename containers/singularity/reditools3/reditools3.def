Bootstrap: docker
From: python:slim-bullseye

%post
    apt-get update && apt-get install -y procps
    pip install REDItools3==3.6

%environment
    export PATH=/usr/local/bin/:$PATH

%runscript
    exec bash "$@"

%labels
    Author eascarrunz.dev@mailfence.com
    Tool REDItools3

%help
    Container for REDItools3.
